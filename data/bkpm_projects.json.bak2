      "source_url": "https://regionalinvestment.bkpm.go.id/daerah/peluang_investasi/221",
      "scraped_at": "2026-05-01T20:52:29Z",
      "last_verified_at": "2026-05-02T21:41:18Z",
      "project_type": "PID"
    },
