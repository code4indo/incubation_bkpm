    {
      "id": 289,
      "name_id": "Pembangunan Objek Wisata Seribu Gua Desa Banuarea Kabupaten Humbang Hasundutan",
      "name_en": "Pembangunan Objek Wisata Seribu Gua Desa Banuarea Kabupaten Humbang Hasundutan",
      "district": "",
      "province": "Sumatera Utara",
      "province_code": "12",
      "kbli_codes": [],
      "investment_value_text": "Rp 33,8M",
      "investment_value_idr": 33800000.0,
